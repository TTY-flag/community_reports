  "high_risk_areas": [
    {
      "area": "变长参数处理",
      "description": "AllGatherV/AlltoAllV/ReduceScatterV等算子接收外部传入的数组参数",
      "risk_factors": [
        "recvCounts/recvDispls/sendCounts/sendDispls等数组由外部传入",
        "数组内容直接影响缓冲区偏移计算",
        "可能导致缓冲区越界或整数溢出"
      ],
      "affected_modules": ["all_gather_v", "all_to_all_v", "reduce_scatter_v"]
    },
    {
      "area": "跨Rank数据传输",
      "description": "Send/Recv/BatchSendRecv涉及跨进程/跨服务器的数据传输",
      "risk_factors": [
        "数据通过网络传输，可能被篡改",
        "destRank/srcRank参数控制目标节点",
        "缓冲区大小和数据量需要严格匹配"
      ],
      "affected_modules": ["send", "recv", "batch_send_recv"]
    },
    {
      "area": "动态库加载",
      "description": "使用dlopen/dlsym动态加载libhcomm.so",
      "risk_factors": [
        "库路径可能被篡改",
        "符号查找失败可能导致运行时错误"
      ],
      "affected_modules": ["hcomm_dlsym"]
    },
    {
      "area": "Binary文件加载",
      "description": "AIV模式需要加载kernel binary文件",
      "risk_factors": [
        "binary路径由ASCEND_HOME_PATH环境变量决定",
        "文件可能被替换或篡改"
      ],
      "affected_modules": ["op_common_template_aiv"]
    },
    {
      "area": "序列化/反序列化",
      "description": "OpParam和拓扑信息的序列化传输",
      "risk_factors": [
        "序列化数据在Host和Device之间传递",
        "反序列化过程可能存在缓冲区处理问题"
      ],
      "affected_modules": ["op_common_template", "common"]
    },
    {
      "area": "环境变量解析",
      "description": "多个环境变量控制通信行为",
      "risk_factors": [
        "环境变量可被外部设置",
        "错误的配置可能导致通信失败或安全问题"
      ],
      "affected_modules": ["common"]
    }
  ],
