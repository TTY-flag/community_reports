    "data_flow_paths": [
      {
        "name": "user_api_to_task_schedule",
        "description": "User calls instruction API -> Instruction object created -> Task scheduled -> C++ scheduling",
        "path": [
          "mskpp/apis.py:InstrApiRegister.get()",
          "mskpp/intrisic_api/instr_register.py:InstrRegister.register()",
          "mskpp/core/computation_instruction.py:ComputationInstruction.__init__()",
          "mskpp/core/instr_task.py:InstrTask",
          "mskpp/_C/task_schedule:Schedule.add_task()",
          "csrc/interface/init_schedule_module.cpp:MSKPP_SCHEDULE_AddTask()",
          "csrc/core/task_schedule/task_schedule.cpp:TaskSchedule::AddTask()",
          "csrc/core/task_schedule/raw_task.cpp:RawTask::Run()"
        ]
      },
      {
        "name": "tensor_creation_to_memory_instruction",
        "description": "User creates Tensor -> Memory instruction created -> Performance data lookup",
        "path": [
          "mskpp/core/tensor.py:Tensor.__init__()",
          "mskpp/core/tensor.py:Tensor.load()",
          "mskpp/core/memory_instruction.py:MemoryInstruction",
          "mskpp/_C/prof_data:MOV.get()",
          "csrc/interface/init_profdata_module.cpp:MSKPP_PROFDATA_MOVRegister()",
          "csrc/prof_data/data_adapter.cpp:MovClass::Get()",
          "csrc/prof_data/resource910b.cpp:GetMovTypeData()"
        ]
      },
      {
        "name": "trace_output",
        "description": "Performance trace data collected and written to JSON file",
        "path": [
          "mskpp/core/trace.py:Trace.add_event()",
          "mskpp/core/trace.py:Trace.dump()",
          "mskpp/core/trace.py:os.fdopen(os.open(...))",
          "json.dumps(trace_obj)"
        ]
      },
      {
        "name": "dependency_download",
        "description": "External dependency download via HTTP",
        "path": [
          "build.py:BuildManager.run()",
          "download_dependencies.py:DependencyManager.run()",
          "download_dependencies.py:DependencyManager.proc_artifact()",
          "subprocess.run(['curl', '-Lfk', ...])",
          "tar -xf <archive>",
          "shutil.move(source, target)"
        ]
      }
    ],
