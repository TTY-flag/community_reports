{
  "project_name": "MindStudio-Kernel-Performance-Prediction",
  "project_type": "python_library_with_cpp_extension",
  "description": "Ascend AI Operator Performance Prediction Tool (msKPP) - A performance simulation tool that predicts upper performance limits for operators based on input/output sizes, returning results in seconds without actual computation execution.",
  "version": "0.0.0.dev0",
  "language": ["Python", "C++"],
  "build_system": ["CMake", "setuptools", "build.py"],
  "entry_points": {
    "python_api": {
      "module": "mskpp",
      "exports": [
        "Tensor",
        "Chip",
        "Core",
        "set_flag",
        "wait_flag",
        "VecScope",
        "mmad",
        "vadd",
        "rv_vadd",
        "rv_vsub",
        "rv_vmax",
        "rv_vmin",
        "rv_vabsdif",
        "rv_vadds",
        "vadds",
        "vmul",
        "vmuls",
        "vexp",
        "vsub",
        "vln",
        "vmax",
        "vector_dup",
        "vbrcb",
        "vconv",
        "vdiv",
        "vcadd",
        "vtranspose",
        "vcgmax",
        "vmaxs",
        "vrec",
        "vrsqrt",
        "vsel",
        "vshl",
        "vshr",
        "vsqrt",
        "vsubreluconv",
        "vsubrelu",
        "vcmax",
        "vabs",
        "vaddreluconv",
        "vaddrelu",
        "vand",
        "vaxpy",
        "vcgadd",
        "vcgmin",
        "vcmin",
        "vcmp",
        "vcmpv",
        "vcmpvs",
        "vcopy",
        "vcpadd",
        "vmin",
        "vmins",
        "vrelu",
        "vnot",
        "vmaddrelu",
        "vmla",
        "vreducev2",
        "vreduce",
        "vor",
        "vmulconv",
        "vgather",
        "vgatherb",
        "vlrelu",
        "vmadd",
        "vbitsort",
        "vmrgsort",
        "vconv_deq",
        "vconv_vdeq"
      ]
    },
    "build_scripts": [
      "build.py",
      "download_dependencies.py"
    ],
    "examples": [
      "example/sample_vadd.py",
      "example/sample_mmad.py",
      "example/sample_sync.py"
    ]
  },
  "attack_surface": {
    "entry_points": [
      {
        "type": "python_api",
        "description": "Python library API - User code imports mskpp and calls instruction APIs",
        "location": "mskpp/__init__.py, mskpp/apis.py",
        "risk_level": "medium",
        "data_flow": "User Python code -> mskpp module -> C++ extension (_C.so) -> Task scheduling"
      },
      {
        "type": "file_input",
        "description": "Trace JSON output - Performance trace data written to files",
        "location": "mskpp/core/trace.py",
        "risk_level": "low",
        "data_flow": "Trace.dump() -> JSON file output"
      },
      {
        "type": "file_output",
        "description": "CSV and visualization output - Metrics data output",
        "location": "mskpp/core/metric/output_tool.py, mskpp/core/metric/visualization_tool.py",
        "risk_level": "low",
        "data_flow": "Performance metrics -> CSV/HTML/JSON output files"
      },
      {
        "type": "dependency_download",
        "description": "External dependency download via download_dependencies.py",
        "location": "download_dependencies.py",
        "risk_level": "high",
        "data_flow": "HTTP download -> tar extraction -> file system write"
      },
      {
        "type": "python_c_binding",
        "description": "Python-C++ interface via C extension module",
        "location": "csrc/interface/*.cpp",
        "risk_level": "high",
        "data_flow": "Python PyObject -> C++ native code -> Data processing"
      }
    ],
    "data_sources": [
      {
        "type": "user_input",
        "description": "Tensor parameters (mem_type, dtype, size, format)",
        "location": "mskpp/core/tensor.py",
        "validation": "Parameter validation in Tensor.param_check()"
      },
      {
        "type": "user_input",
        "description": "Chip configuration (chip type string)",
        "location": "csrc/interface/init_arch_module.cpp",
        "validation": "PyUnicode_AsUTF8AndSize for string extraction"
      },
      {
        "type": "user_input",
        "description": "Instruction parameters (granularity, instruction type)",
        "location": "csrc/interface/init_profdata_module.cpp",
        "validation": "PyArg_ParseTuple for argument parsing"
      }
    ],
    "external_dependencies": [
      {
        "name": "plotly",
        "version": ">=5.11.0",
        "usage": "Data visualization",
        "risk": "low - display only"
      },
      {
        "name": "pandas",
        "version": ">=1.0.0",
        "usage": "Data analysis",
        "risk": "low - computation only"
      },
