  "excluded_directories": [
    "test/",
    "thirdparty/",
    "example/",
    "docs/"
  ],
  "security_features": {
    "file_permission_checks": {
      "location": "mskpp/utils/safe_check.py, mskpp/core/metric/file_system.py",
      "description": "Checks file ownership, permissions, symbolic links"
    },
    "input_validation": {
      "location": "mskpp/core/common/checker.py",
      "description": "Validates mem_type, dtype, format, shape parameters"
    },
    "compiler_flags": {
      "location": "CMakeLists.txt",
      "description": "Uses security flags: -fstack-protector-all, -D_FORTIFY_SOURCE=2, -ftrapv, -fstack-check, -Wl,-z,relro, -Wl,-z,now, -Wl,-z,noexecstack"
    },
    "file_write_protection": {
      "location": "mskpp/core/trace.py, mskpp/core/metric/output_tool.py",
      "description": "Uses os.fdopen with secure permissions (S_IWUSR | S_IRUSR)"
