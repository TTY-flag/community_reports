      "files": [
        "csrc/interface/init_arch_module.cpp",
        "csrc/interface/init_profdata_module.cpp",
        "csrc/interface/init_schedule_module.cpp"
      ],
      "reason": "Python-C++ binding code with PyObject manipulation - potential for type confusion, memory safety issues"
    },
    {
      "area": "external_download",
      "files": [
        "download_dependencies.py"
      ],
      "reason": "Downloads external packages via HTTP and extracts archives - potential for supply chain attacks, malicious packages"
    },
    {
      "area": "file_operations",
      "files": [
        "mskpp/core/trace.py",
        "mskpp/core/metric/output_tool.py",
        "mskpp/core/metric/file_system.py"
      ],
      "reason": "File I/O operations - potential for path traversal, insufficient permission checks"
    },
    {
      "area": "user_input_validation",
      "files": [
        "mskpp/core/tensor.py",
        "mskpp/core/common/checker.py"
      ],
      "reason": "User input handling for tensor parameters - potential for insufficient validation leading to buffer overflows or integer overflow"
    },
    {
      "area": "string_handling",
      "files": [
        "csrc/interface/init_arch_module.cpp",
        "csrc/interface/init_profdata_module.cpp"
      ],
      "reason": "C++ string handling with PyUnicode_AsUTF8AndSize - potential for null pointer dereference, buffer overflow"
    }
